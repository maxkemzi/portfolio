{
	"name": "portfolio",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"test:build": "NODE_ENV=test npm run build",
		"start": "next start",
		"test:start": "NODE_ENV=test npm start",
		"lint": "next lint && tsc --noEmit --incremental && prettier --check **/*.{js,jsx,ts,tsx,json,md,rc}",
		"fmt": "prettier --write **/*.{js,jsx,ts,tsx,json,md,rc}",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "npm run test:unit && npm run test:e2e",
		"coverage": "vitest run --coverage",
		"db:push": "dotenv -e .env.local -- npx prisma db push",
		"test:db:push": "dotenv -e .env.test.local -- npx prisma db push",
		"test:db:seed": "dotenv -e .env.test.local -- npx prisma db seed"
	},
	"prisma": {
		"seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
	},
	"dependencies": {
		"@hookform/resolvers": "^3.9.0",
		"@phosphor-icons/react": "^2.1.7",
		"@prisma/client": "^5.17.0",
		"@types/nodemailer": "^6.4.15",
		"@types/uuid": "^10.0.0",
		"framer-motion": "^11.3.19",
		"next": "14.2.5",
		"next-safe-action": "^7.4.3",
		"nodemailer": "^6.9.14",
		"prisma": "^5.17.0",
		"react": "^18",
		"react-dom": "^18",
		"react-hook-form": "^7.52.2",
		"react-markdown": "^9.0.1",
		"remark-gfm": "^4.0.0",
		"sharp": "^0.33.5",
		"tailwind-merge": "^2.5.2",
		"uuid": "^10.0.0",
		"zod": "^3.23.8",
		"zod-form-data": "^2.0.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.47.1",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.5.0",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.5.2",
		"@types/node": "^20",
		"@types/react": "^18",
		"@types/react-dom": "^18",
		"@typescript-eslint/eslint-plugin": "^7.17.0",
		"@typescript-eslint/parser": "^7.17.0",
		"@vitejs/plugin-react": "^4.3.1",
		"@vitest/coverage-v8": "^2.0.5",
		"@vitest/ui": "^2.0.5",
		"dotenv-cli": "^7.4.2",
		"eslint": "^8.57.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-airbnb-typescript": "^18.0.0",
		"eslint-config-next": "14.2.5",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-jsx-a11y": "^6.9.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-react": "^7.35.0",
		"eslint-plugin-react-hooks": "^4.6.2",
		"postcss": "^8",
		"prettier": "^3.3.3",
		"tailwindcss": "^3.4.1",
		"ts-node": "^10.9.2",
		"typescript": "^5",
		"vitest": "^2.0.4"
	}
}
