generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "mongodb"
   url      = env("DATABASE_URL")
}

model rateLimit {
   id           String @id @default(auto()) @map("_id") @db.ObjectId
   ip           String @unique
   requestCount Int    @default(0)
   resetTime    BigInt
}
